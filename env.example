# ─────────────────────────────────────────────────────────────
#  syshealth.py — Time Machine Konfiguration
#  Datei:  .env   (liegt im gleichen Ordner wie syshealth.py)
#
#  ⚠  WICHTIG: Diese Datei ins .gitignore eintragen!
#              Niemals mit ins Repo pushen.
# ─────────────────────────────────────────────────────────────

# Hostname oder IP deines NAS / Time Capsule
TM_HOST=Dockfish

# Name des Freigabe-Ordners auf dem NAS (SMB-Share)
TM_SHARE=TimeMachine

# Benutzername für den SMB-Zugriff
TM_USER=backup

# Passwort für den SMB-Zugriff
TM_PASS=deinGeheimesPasswort

# Optional: filtert nach einem bestimmten Maschinennamen
# (nützlich wenn mehrere Macs auf denselben Share sichern)
# TM_MACHINE=MacBook-von-Mark
